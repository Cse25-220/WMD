body {
    font-family: Arial, sans-serif;
    color: #333;
    background-color: #f9f9f9;
    margin: 0;
    line-height: 1.6;
}

header {
    background-color: #3e77a3;
}

/* Override Bootstrap navbar color */
.navbar {
    background-color: #3e77a3 !important;
}

.navbar a {
    color: white !important;
}

.navbar a:hover {
    color: #add8e6 !important;
    text-decoration: underline;
}

main {
    padding: 20px;
    max-width: 900px;
    margin: auto;
}

img {
    max-width: 100%;
    height: auto;
    border: 5px solid #add8e6;
    border-radius: 10px;
}

p {
    font-size: 1.1em;
}

a {
    color: #3e77a3;
    text-decoration: none;
}

a:hover {
    text-decoration: underline;
}

footer {
    background-color: #add8e6;
    color: #333;
    text-align: center;
    padding: 15px;
    margin-top: 40px;
}
